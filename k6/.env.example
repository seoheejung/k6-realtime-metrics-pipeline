# 테스트 대상 API
BASE_URL=http://localhost:8080
TARGET_PATH=/health

# 요청 타임아웃
REQUEST_TIMEOUT=5s

# load 테스트
LOAD_VUS=10
LOAD_DURATION=30s

# stress 테스트
STRESS_START_VUS=1
STRESS_STAGE_1_TARGET=10
STRESS_STAGE_2_TARGET=30
STRESS_STAGE_3_TARGET=50

# Kafka 설정
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=k6-metrics

# Docker 이미지
K6_IMAGE=k6-kafka
